---
import FiltroIcon from '../assets/icons/Filtro.astro';
import BusquedaIcon from '../assets/icons/Busqueda.astro';
import UserIcon from '../assets/icons/User.astro';
import InterrogacionIcon from '../assets/icons/Interrogacion.astro';
import MenuIcon from '../assets/icons/Menu.astro';

import LogoImg from '../assets/img/logo.png';

import CasaMenuImg from '../assets/img/casa-menu.png';
import CarritoMenuImg from '../assets/img/carrito-menu.png';
import MapaMenuImg from '../assets/img/mapa-menu.png';
import PuntosMenuImg from '../assets/img/puntos-menu.png';
import EstrellaMenuImg from '../assets/img/estrella-menu.png';
---

<nav class="w-full flex flex-col min-[720px]:grid min-[720px]:grid-cols-3 min-[720px]:items-center bg-[#DBC5D9] min-[720px]:bg-[#7E1C87] relative z-[999]"
     style="padding: 1rem 2rem;">

    <!-- COLUMNA 1: Logo -->
    <div id="nav-logo" class="flex justify-between min-[720px]:justify-start w-full min-[720px]:w-auto items-center gap-2 mb-3 min-[720px]:mb-0">
        <figure>
            <img src={LogoImg.src} alt="Logo" class="w-16 min-[720px]:w-9"/>
        </figure>
        <a class="uppercase flex flex-col text-xl min-[720px]:text-lg justify-center font-serif" href="/Libreria-Valeria">
            El Gran <span class="m-auto" style="color: var(--color-secondary);">Lector</span>
        </a>
        <button id="menu-btn-mobile" class="cursor-pointer min-[720px]:hidden">
            <MenuIcon class="w-8 h-8" />
        </button>
    </div>

    <!-- COLUMNA 2: Buscador -->
