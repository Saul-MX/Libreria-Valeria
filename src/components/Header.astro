                </li>
                <li class="relative">
                    <button data-submenu="sub-libros" class="submenu-btn w-full flex justify-between items-center px-4 py-2 hover:bg-purple-100 font-semibold rounded-lg">
                        AudioLibros <span class="ml-2">›</span>
                    </button>
                    <ul id="sub-libros" class="hidden absolute left-full top-0 w-44 border border-neutral-900 rounded-xl shadow-lg px-1 py-1" style="background: #DBC5D9;">
