                <li class="border-t border-neutral-900 pt-2">
                    <a href="#" class="block px-4 py-2 text-red-400 hover:bg-red-50 rounded-lg">Limpiar filtros</a>
                </li>
            </ul>
        </div>

        <input type="text" placeholder="Buscar..."
            class="flex-1 min-w-0 max-w-[120px] min-[720px]:max-w-none min-[720px]:w-64 bg-white border border-gray-300 rounded-lg px-2 py-2 focus:outline-none focus:ring-2 focus:ring-fuchsia-300"
        />

        <button class="cursor-pointer">
            <BusquedaIcon class="w-8 h-8 min-[720px]:w-9 min-[720px]:h-9" />
