        <button id="filtro-btn" class="busqueda-filtro cursor-pointer hidden min-[720px]:block">
            <FiltroIcon class="w-9 h-9" />
        </button>

        <!-- Dropdown filtro -->
        <div style="background: #DBC5D9;" id="filtro-dropdown"
     class="hidden absolute top-12 left-1/3 -translate-x-1/2 min-[720px]:translate-x-0 min-[720px]:left-0 w-48 min-[720px]:w-56 border border-neutral-900 rounded-xl shadow-lg z-[999]">
