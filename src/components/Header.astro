    <!-- COLUMNA 3: Íconos derecha -->
    <div id="nav-iconos" class="hidden min-[720px]:flex items-center gap-4 justify-end">
        <a href="/Libreria-Valeria/login" class="cursor-pointer nav-icon"><UserIcon class="w-9 h-9" /></a>
        <a class="cursor-pointer nav-icon"><InterrogacionIcon class="w-9 h-9" /></a>
