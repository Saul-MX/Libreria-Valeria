                        <li><a href="#" class="block px-4 py-2 hover:bg-purple-100 rounded-lg">Ilustrados</a></li>
                    </ul>
                </li>
                <li class="relative">
                    <button data-submenu="no-de-paginas" class="submenu-btn w-full flex justify-between items-center px-4 py-2 hover:bg-purple-100 font-semibold rounded-lg">
                        No. de páginas <span class="ml-2">›</span>
                    </button>
                    <ul id="no-de-paginas" class="hidden absolute left-full top-0 w-44 border border-neutral-900 rounded-xl shadow-lg px-1 py-1" style="background: #DBC5D9;">
                        <li><a href="/Libreria-Valeria/no-de-paginas" class="block px-4 py-2 hover:bg-purple-100 rounded-lg">Mas de 150</a></li>
                    </ul>
