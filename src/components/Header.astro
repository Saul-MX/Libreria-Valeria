    </div>

</nav>

<!-- Overlay oscuro -->
<div id="menu-overlay" class="fixed inset-0 bg-black/40 z-40 hidden" style="z-index: 9999998;"></div>

<!-- Drawer lateral derecho -->
<aside
    id="menu-drawer"
    class="fixed top-0 right-0 h-full w-56 z-50 translate-x-full transition-transform duration-300 ease-in-out overflow-y-auto"
    style="background-color: var(--color-primary); border-radius: 1rem 0 0 1rem; z-index: 9999999;"
>
    <div class="flex items-center justify-between px-3 py-3 border-b border-neutral-800 sticky top-0"
         style="background-color: var(--color-primary);">
        <span class="text-white font-bold text-sm">Menú</span>
        <button id="menu-close"
                class="bg-white text-purple-900 w-7 h-7 rounded-full font-bold cursor-pointer flex items-center justify-center text-sm">
            ✕
        </button>
    </div>

    <ul class="flex flex-col">
        <li class="drawer-item">
            <a href="#" class="flex items-center gap-3 px-4 py-4 border-b border-neutral-800 hover:brightness-110 transition-all">
                <span class="w-10 h-10 rounded-lg flex items-center justify-center">
                    <img src={CasaMenuImg.src} alt="Inicio" />
                </span>
                <span class="text-white font-semibold text-lg">Inicio</span>
            </a>
        </li>
        <li class="drawer-item">
            <a href="#" class="flex items-center gap-3 px-4 py-4 border-b border-neutral-800 hover:brightness-110 transition-all">
                <span class="w-10 h-10 rounded-lg bg-yellow-500 flex items-center justify-center">
                    <img src={EstrellaMenuImg.src} alt="Favoritos" />
                </span>
                <span class="text-white font-semibold text-lg">Favoritos</span>
            </a>
        </li>
        <li class="drawer-item">
            <a href="#" class="flex items-center gap-3 px-4 py-4 border-b border-neutral-800 hover:brightness-110 transition-all">
                <span class="w-10 h-10 rounded-lg bg-red-500 flex items-center justify-center">
                    <img src={MapaMenuImg.src} alt="Sucursales" />
                </span>
                <span class="text-white font-semibold text-lg">Sucursales</span>
            </a>
        </li>
        <li class="drawer-item">
            <a href="#" class="flex items-center gap-3 px-4 py-4 border-b border-neutral-800 hover:brightness-110 transition-all">
                <span class="w-10 h-10 rounded-lg bg-blue-500 flex items-center justify-center">
                    <img src={PuntosMenuImg.src} alt="Mis Puntos" />
                </span>
                <span class="text-white font-semibold text-lg">Mis Puntos</span>
            </a>
        </li>
        <li class="drawer-item">
            <a href="#" class="flex items-center gap-3 px-4 py-4 border-b border-neutral-800 hover:brightness-110 transition-all">
                <span class="w-10 h-10 rounded-lg bg-purple-700 flex items-center justify-center">
                    <img src={CarritoMenuImg.src} alt="Carrito" />
                </span>
                <span class="text-white font-semibold text-lg">Carrito</span>
            </a>
        </li>
    </ul>
</aside>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

<script is:inline>
    // ── Drawer logic ──
    const menuDrawer = document.getElementById("menu-drawer");
    const menuOverlay = document.getElementById("menu-overlay");
    const menuClose = document.getElementById("menu-close");

    function openDrawer() {
        menuDrawer.classList.remove("translate-x-full");
        menuOverlay.classList.remove("hidden");
        document.body.style.overflow = "hidden";
        document.body.style.overflowX = "hidden";

        // Anima los items del drawer al abrirse
        gsap.from('.drawer-item', {
            x: 60,
            opacity: 0,
            duration: 0.35,
            stagger: 0.08,
            ease: 'power2.out',
        });
    }

    function closeDrawer() {
        menuDrawer.classList.add("translate-x-full");
        menuOverlay.classList.add("hidden");
        document.body.style.overflow = "";
        document.body.style.overflowX = "";
    }

    document.getElementById("menu-btn")?.addEventListener("click", openDrawer);
    document.getElementById("menu-btn-mobile")?.addEventListener("click", openDrawer);
    menuClose.addEventListener("click", closeDrawer);
    menuOverlay.addEventListener("click", closeDrawer);

    // Filtro — desktop y mobile comparten el mismo dropdown
    const filtroBtn = document.getElementById("filtro-btn");
    const filtroBtnMobile = document.getElementById("filtro-btn-mobile");
    const filtroDropdown = document.getElementById("filtro-dropdown");

    function toggleFiltro(e) {
        e.stopPropagation(); // evita que el click se propague al document
        const isHidden = filtroDropdown.classList.contains("hidden");
        filtroDropdown.classList.toggle("hidden");
        if (isHidden) {
            gsap.from(filtroDropdown, {
                y: -10,
                opacity: 0,
                duration: 0.25,
                ease: 'power2.out',
            });
        }
    }

    filtroBtn?.addEventListener("click", toggleFiltro);
    filtroBtnMobile?.addEventListener("click", toggleFiltro);

    // UN solo listener para cerrar al tocar fuera
    document.addEventListener("click", (e) => {
        if (filtroDropdown &&
            !filtroDropdown.contains(e.target)) {
            filtroDropdown.classList.add("hidden");
        }
    });

    // Submenús — click en mobile, hover en desktop
    document.querySelectorAll('.submenu-btn').forEach(btn => {
        // Click para mobile
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const targetId = btn.getAttribute('data-submenu');
            const submenu = document.getElementById(targetId);

            // Cierra los demás
            document.querySelectorAll('.submenu-list').forEach(el => {
                if (el.id !== targetId) el.classList.add('hidden');
            });

            submenu.classList.toggle('hidden');
        });

        // Hover para desktop
        const li = btn.parentElement;
        const targetId = btn.getAttribute('data-submenu');
        const submenu = document.getElementById(targetId);

        li.addEventListener('mouseenter', () => {
            if (window.innerWidth >= 720) submenu.classList.remove('hidden');
        });
        li.addEventListener('mouseleave', () => {
            if (window.innerWidth >= 720) submenu.classList.add('hidden');
        });
    });

    // ── Animaciones de entrada del nav ──
    gsap.from('#nav-logo', {
        x: -40,
        opacity: 0,
        duration: 0.6,
        ease: 'power2.out',
    });

    gsap.from('#nav-buscador', {
        y: -20,
        opacity: 0,
        duration: 0.6,
        delay: 0.15,
        ease: 'power2.out',
    });

    gsap.from('#nav-iconos', {
        x: 40,
        opacity: 0,
        duration: 0.6,
        delay: 0.25,
        ease: 'power2.out',
    });

    // Hover en íconos del nav
    document.querySelectorAll('.nav-icon').forEach(el => {
        el.addEventListener('mouseenter', () => {
            gsap.to(el, { scale: 1.2, duration: 0.15, ease: 'power1.out' });
        });
        el.addEventListener('mouseleave', () => {
            gsap.to(el, { scale: 1, duration: 0.15, ease: 'power1.out' });
        });
    });
</script>