---
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

import cienAnosImg from '../assets/img/no-de-paginas/cien-anos.png';
import gritoImg from '../assets/img/no-de-paginas/grito.png';
import antesDiciembreImg from '../assets/img/no-de-paginas/antes-diciembre.png';
import ciudadesPapelImg from '../assets/img/no-de-paginas/ciudades-papel.png';
import mismaEstrellaImg from '../assets/img/no-de-paginas/misma-estrella.png';
import harryPotterImg from '../assets/img/no-de-paginas/harry-potter.png';
import mujercitasImg from '../assets/img/no-de-paginas/mujercitas.png';
import coralineImg from '../assets/img/no-de-paginas/coraline.png';
import pijamaRayasImg from '../assets/img/no-de-paginas/pijama-rayas.png';
import razonContigoImg from '../assets/img/no-de-paginas/razon-contigo.png';
import resplandorImg from '../assets/img/no-de-paginas/resplandor.png';

const libros = [
    { titulo: "Cien años de soledad", paginas: 496, img: cienAnosImg.src },
    { titulo: "Un grito desesperado", paginas: 189, img: gritoImg.src },
    { titulo: "Antes de Diciembre", paginas: 496, img: antesDiciembreImg.src },
    { titulo: "Ciudades de Papel", paginas: 368, img: ciudadesPapelImg.src },
    { titulo: "Bajo la misma estrella", paginas: 301, img: mismaEstrellaImg.src },
    { titulo: "H.P. y la piedra filosofal", paginas: 296, img: harryPotterImg.src },
    { titulo: "Mujercitas", paginas: 400, img: mujercitasImg.src },
    { titulo: "Coraline", paginas: 160, img: coralineImg.src },
    { titulo: "El niño con el pijama de rayas", paginas: 224, img: pijamaRayasImg.src },
    { titulo: "La razón de estar contigo", paginas: 320, img: razonContigoImg.src },
    { titulo: "El Resplandor", paginas: 418, img: resplandorImg.src }
];
---

<Layout>
    <Header />
        <section class="w-full py-8 px-6 min-[720px]:px-10" style="background-color: var(--color-secondary);">
            <div class="grid grid-cols-2 min-[720px]:grid-cols-3 lg:grid-cols-5 gap-4">
                {libros.map((libro) => (
                    <div class="flex flex-col rounded-2xl overflow-hidden p-3 gap-2 relative"
                        style="background-color: #7B3FA0;">

                        <!-- Estrella favoritos -->
                        <button class="absolute top-3 right-3 cursor-pointer transition-transform z-10 flex items-center justify-center"
                        style="background-color: var(--color-secondary);
                            width: 32px;
                            height: 32px;
                            border-radius: 5px;">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                            </svg>
                        </button>

                        <!-- Portada del libro -->
                        <div class="w-full aspect-[2/3] overflow-hidden rounded-lg bg-gray-800 flex items-center justify-center">
                            <img
                                src={libro.img}
                                alt={libro.titulo}
                                class="w-full h-full object-cover"
                            />
                            <div class="hidden w-full h-full items-center justify-center bg-gray-700 rounded-lg">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
                                </svg>
                            </div>
                        </div>

                        <!-- Info -->
                        <div class="flex flex-col gap-1 flex-1">
                            <p class="text-white text-2xl font-normal leading-tight text-title">
                                {libro.titulo}<br/>
                                <span class="text-white/80 text-xl text-page">{libro.paginas} páginas.</span>
                            </p>
                        </div>

                        <!-- Botón comprar -->
                        <a href="/Libreria-Valeria/sinopsis"  class="w-full bg-white text-black text-xs font-bold tracking-widest py-2 rounded cursor-pointer hover:bg-gray-100 transition-colors uppercase items-center flex justify-center ">
                            Comprar
                        </a>
                    </div>
                ))}
            </div>
        </section>
    <Footer />
</Layout>

<style>
    @media (max-width: 720px) {
        section {
            background-color: #DBC5D9 !important;
        }

        .text-page{
            font-size: 1rem !important;
        }

        .text-title{
            font-size: 1.25rem !important;
        }
    }
</style>