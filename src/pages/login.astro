---
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

import LibDescuento from '../assets/img/login/lib-descuento.png';
---

<Layout>
    <Header />

    <main class="w-full min-h-screen flex flex-col lg:flex-row login-main" style="background-color: #D9D9D9;">

        <!-- SECCIÓN LOGIN -->
        <section id="login-section" class="flex-1 flex flex-col items-center justify-center py-12 px-6">

            <h1 id="login-title" class="text-4xl lg:text-5xl font-bold tracking-widest text-black mb-8 uppercase">
                Inicia Sesión
            </h1>

            <div class="w-full max-w-md flex flex-col gap-5">

                <!-- Email -->
                <div id="campo-email" class="flex flex-col gap-1">
                    <label class="text-base text-black">Introduce tu correo electrónico</label>
                    <div class="flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 shrink-0" fill="none" viewBox="0 0 24 24" stroke="black" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                            <circle cx="6" cy="17" r="2" fill="black" stroke="none"/>
                        </svg>
                        <input
                            type="email"
                            placeholder="ejem. hola123@gmail.com"
                            class="flex-1 px-4 py-3 rounded text-white placeholder-white/80 focus:outline-none focus:ring-2 focus:ring-purple-300"
                            style="background-color: #B57DA7;"
                        />
                    </div>
                </div>

                <!-- Contraseña -->
                <div id="campo-password" class="flex flex-col gap-1">
                    <label class="text-base text-black">Introduce tu contraseña</label>
                    <div class="flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 shrink-0" fill="none" viewBox="0 0 24 24" stroke="black" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
                        </svg>
                        <input
                            type="password"
                            placeholder=""
                            class="flex-1 px-4 py-3 rounded focus:outline-none focus:ring-2 focus:ring-purple-300"
                            style="background-color: #B57DA7;"
                        />
                    </div>
                </div>

                <!-- Botón -->
                <button
                    id="login-btn"
                    class="w-full py-3 text-white font-bold tracking-widest uppercase rounded cursor-pointer mt-2"
                    style="background: #923B88;"
                >
                    Iniciar Sesión
                </button>

                <!-- Registro -->
                <p id="login-registro" class="text-center text-sm text-black">
                    ¿No tienes una cuenta?,
                    <a href="#" class="underline hover:opacity-70">registrate aquí</a>
                </p>

            </div>
        </section>

        <!-- BANNERS — solo mobile -->
        <aside id="login-aside" class="w-full lg:hidden flex flex-col gap-0"
               style="background-color: #dbc5d9;">

            <!-- Banner promoción -->
            <div id="banner-promo" class="flex items-center gap-3 px-4 py-4 bg-white border-8 border-purple-300 align-center mb-16 justify-around">
                <div class="w-16 h-20 shrink-0 rounded overflow-hidden bg-gray-300 flex items-center justify-center">
                    <img src={LibDescuento.src} alt="Libro Descuento" class="w-full h-full object-cover"/>
                </div>
                <div class="flex flex-col text-red-600 font-bold text-2xl leading-tight">
                    <span>DEL</span>
                    <span>22/06 AL</span>
                    <span>04/10</span>
                </div>
                <div class="w-20 h-20 shrink-0 rounded-full border-4 border-yellow-400 bg-yellow-50 flex flex-col items-center justify-center shadow">
                    <span class="text-2xl font-black text-black leading-none">50%</span>
                    <span class="text-xs font-bold text-black leading-none">off</span>
                </div>
                <div class="font-bold text-2xl leading-tight text-black">
                    COMPRA<br/>YA!
                </div>
            </div>

        </aside>

    </main>

    <Footer />
</Layout>

<style>
    @media (max-width: 1024px) {
        .login-main {
            background-color: #DBC5D9 !important;
        }
    }
</style>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

<script is:inline>
    const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });

    // Título cae desde arriba
    tl.from('#login-title', {
        y: -50,
        opacity: 0,
        duration: 0.6,
    })
    // Email sube desde abajo
    .from('#campo-email', {
        y: 30,
        opacity: 0,
        duration: 0.45,
    }, '-=0.2')
    // Contraseña sube desde abajo con delay
    .from('#campo-password', {
        y: 30,
        opacity: 0,
        duration: 0.45,
    }, '-=0.25')
    // Botón escala desde pequeño
    .from('#login-btn', {
        scale: 0.8,
        opacity: 0,
        duration: 0.4,
    }, '-=0.2')
    // Texto registro aparece
    .from('#login-registro', {
        opacity: 0,
        duration: 0.35,
    }, '-=0.1');

    // Banners mobile — entran desde abajo
    gsap.from('#banner-promo', {
        y: 50,
        opacity: 0,
        duration: 0.6,
        delay: 0.5,
        ease: 'power2.out',
    });

    gsap.from('#banner-estrella', {
        y: 50,
        opacity: 0,
        duration: 0.6,
        delay: 0.7,
        ease: 'power2.out',
    });

    // Hover en botón — pulso suave
    const loginBtn = document.getElementById('login-btn');
    loginBtn.addEventListener('mouseenter', () => {
        gsap.to(loginBtn, { scale: 1.03, duration: 0.15, ease: 'power1.out' });
    });
    loginBtn.addEventListener('mouseleave', () => {
        gsap.to(loginBtn, { scale: 1, duration: 0.15, ease: 'power1.out' });
    });
</script>