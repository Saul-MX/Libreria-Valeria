---
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

import resplandorImg from '../assets/img/no-de-paginas/resplandor.png';
---

<Layout>
    <Header />

    <main class="w-full min-h-screen detalle-main" style="background-color: #9C83AA;">

        <!-- CONTENIDO PRINCIPAL -->
        <div class="w-full max-w-5xl mx-auto px-4 py-8 flex flex-col lg:flex-row gap-6">

            <!-- IMAGEN DEL LIBRO -->
            <div class="w-full lg:w-64 shrink-0 flex justify-center lg:justify-start bg-[#7E1C87] p-3 rounded-lg">
                <img
                    src={resplandorImg.src}
                    alt="El Resplandor"
                    class="w-48 lg:w-64 rounded shadow-lg object-cover"
                />
            </div>

            <!-- INFO DERECHA -->
            <div class="flex-1 flex flex-col gap-3">

                <!-- Autor -->
                <p class="text-sm font-bold tracking-widest text-black  uppercase">
                    Stephen King
                </p>

                <!-- Título -->
                <h1 class="text-3xl lg:text-4xl font-black uppercase text-black leading-tight">
                    El Resplandor
                </h1>

                <!-- Editorial y tipo -->
                <div class="flex flex-col gap-1">
                    <p class="text-sm font-bold text-black">
                        Editorial: Penguin Random House Grupo Editorial SA de CV
                    </p>
                    <p class="text-sm font-bold text-black">Tapa blanda</p>
                </div>

                <!-- Favoritos y compartir -->
                <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-2">
                    <div class="flex flex-col gap-1">
                        <button class="flex items-center gap-2 cursor-pointer hover:opacity-70 transition-opacity">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="black" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                            </svg>
                            <span class="text-sm font-medium text-black">Agregar a favoritos</span>
                        </button>
                        <button class="flex items-center gap-2 cursor-pointer hover:opacity-70 transition-opacity">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="black" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z"/>
                            </svg>
                            <span class="text-sm font-medium text-black">Compartir</span>
                        </button>
                    </div>

                    <!-- Precio + Botón — desktop -->
                    <div class="hidden lg:flex flex-col items-end gap-2">
                        <span class="text-3xl font-black text-black">$418.00</span>
                        <button class="px-8 py-3 text-white font-bold tracking-widest uppercase rounded cursor-pointer hover:opacity-90 transition-opacity"
                                style="background-color: var(--color-primary);">
                            Agregar al carrito
                        </button>
                    </div>
                </div>

                <!-- Precio + Botón — mobile -->
                <div class="flex lg:hidden flex-col items-center gap-3 mt-2">
                    <span class="text-3xl font-black text-black">$418.00</span>
                    <button class="w-full py-3 text-white font-bold tracking-widest uppercase rounded cursor-pointer hover:opacity-90 transition-opacity"
                            style="background-color: var(--color-primary);">
                        Agregar al carrito
                    </button>
                </div>

            </div>
        </div>

        <!-- SINOPSIS + CARACTERÍSTICAS -->
        <div class="w-full max-w-5xl mx-auto px-4 pb-10 flex flex-col lg:flex-row gap-8">

            <!-- SINOPSIS -->
            <div class="flex-1">
                <h2 class="text-base font-black uppercase tracking-widest text-black mb-2">Sinopsis</h2>
                <div class="text-sm text-black leading-relaxed">
                    <p id="sinopsis-corta">
                        REDRUM. Ésa es la palabra que Danny había visto en el espejo. Y aunque no sabía leer, entendió que era un mensaje de horror. Una de las historias clásicas del maestro indiscutible de la narrativa de terror contemporánea, que inspiró la no menos clásica adaptación al cine de Stanley Kubrick, The Shining...
                    </p>
                    <p id="sinopsis-completa" class="hidden">
                        REDRUM. Ésa es la palabra que Danny había visto en el espejo. Y aunque no sabía leer, entendió que era un mensaje de horror. Una de las historias clásicas del maestro indiscutible de la narrativa de terror contemporánea, que inspiró la no menos clásica adaptación al cine de Stanley Kubrick, The Shining. REDRUM Ésa es la palabra que Danny había visto en el espejo. Y aunque no sabía leer, entendió que era un mensaje de horror. Danny tenía cinco años. Y a esa edad pocos niños saben que los espejos invierten las imágenes y, menos aún, saben diferenciar entre realidad y fantasía. Pero Danny tenía pruebas de que sus fantasías relacionadas con el resplandor del espejo acabarían cumpliéndose: REDRUM... MURDER, asesinato. Pero su padre necesitaba aquel trabajo en el hotel. Danny sabía que su madre pensaba en el divorcio y que su padre se obsesionaba con algo muy malo, tan malo como la muerte y el suicidio. Sí, su padre necesitaba aceptar la propuesta de cuidar aquel hotel de lujo con más de cien habitaciones, aislado por la nieve durante seis meses. Hasta el deshielo iban a estar solos. Stephen King, el rey del terror. El País Un narrador magistral. Los Angeles Times El indiscutible maestro del suspenso y del terror. The Washington Post
                    </p>
                    <button
                        id="leer-mas-btn"
                        class="text-black font-bold underline cursor-pointer hover:opacity-70 transition-opacity mt-1 text-sm"
                    >
                        Leer más...
                    </button>
                </div>
            </div>

            <!-- CARACTERÍSTICAS -->
            <div class="lg:w-72 shrink-0">
                <h2 class="text-base font-black uppercase tracking-widest text-black mb-3">Características</h2>
                <div class="flex flex-col gap-3">
                    <div class="flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="black" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                        </svg>
                        <span class="text-sm text-black">Número de páginas: 688 páginas</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="black" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253"/>
                        </svg>
                        <span class="text-sm text-black">Idioma: Español</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="black" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5"/>
                        </svg>
                        <span class="text-sm text-black">Fecha de publicación: 1 de octubre de 2013</span>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <Footer />
</Layout>

<style>
    main{
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif !important;
    }
    @media (max-width: 1024px) {
        .detalle-main {
            background-color: #DBC5D9 !important;
        }
    }
</style>

<script is:inline>
    const btn = document.getElementById('leer-mas-btn');
    const corta = document.getElementById('sinopsis-corta');
    const completa = document.getElementById('sinopsis-completa');

    btn.addEventListener('click', () => {
        const expandido = !completa.classList.contains('hidden');
        if (expandido) {
            completa.classList.add('hidden');
            corta.classList.remove('hidden');
            btn.textContent = 'Leer más...';
        } else {
            completa.classList.remove('hidden');
            corta.classList.add('hidden');
            btn.textContent = 'Leer menos';
        }
    });
</script>