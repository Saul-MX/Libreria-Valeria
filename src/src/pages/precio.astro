---
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

import pedroParamoImg from '../assets/img/precio/pedroParamo.png';
import chicoPielCerdoImg from '../assets/img/precio/chico-piel-cerdo.png';
import laOdiseaImg from '../assets/img/precio/la-odisea.png';
import elPrincipitoImg from '../assets/img/precio/pincipito.png';
import comerRezarAmarImg from '../assets/img/precio/comer-rezar-amar.png';
import metamorfosisImg from '../assets/img/precio/metamorfosis.png';
import borrascosasImg from '../assets/img/precio/borrascosas.png';
import draculaImg from '../assets/img/precio/dracula.png';
import yoClaudioImg from '../assets/img/precio/yo-claudio.png';
import hamletImg from '../assets/img/precio/hamlet.png';

const libros = [
    { titulo: "Pedro Páramo", autor: "Juan Rulfo", img: pedroParamoImg.src },
    { titulo: "El chico de la piel de cerdo", autor: "Raiza Revelles", img: chicoPielCerdoImg.src },
    { titulo: "La Odisea", autor: "Homero", img: laOdiseaImg.src },
    { titulo: "El principito", autor: "Antoine de Saint-Exupéry", img: elPrincipitoImg.src },
    { titulo: "Comer, rezar, amar", autor: "Elizabeth Gilbert", img: comerRezarAmarImg.src },
    { titulo: "La metamorfosis", autor: "Franz Kafka", img: metamorfosisImg.src },
    { titulo: "Cumbres Borrascosas", autor: "Emily Bronte", img: borrascosasImg.src },
    { titulo: "Drácula", autor: "Bram Stoker", img: draculaImg.src },
    { titulo: "Yo, Claudio", autor: "Robert Graves", img: yoClaudioImg.src },
    { titulo: "Hamlet", autor: "William Shakespeare", img: hamletImg.src }
];
---

<Layout>
    <Header />
    <section class="w-full py-8 px-6 min-[720px]:px-10" style="background-color: var(--color-secondary);">
        <div class="grid grid-cols-2 min-[720px]:grid-cols-3 lg:grid-cols-5 gap-4">
            {libros.map((libro) => (
                <div class="libro-card flex flex-col rounded-2xl overflow-hidden p-3 gap-2 relative"
                    style="background-color: #7B3FA0;">

                    <button class="fav-btn absolute top-3 right-3 cursor-pointer z-10 flex items-center justify-center"
                        style="background-color: var(--color-secondary); width: 32px; height: 32px; border-radius: 5px;">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                        </svg>
                    </button>

                    <div class="w-full aspect-[2/3] overflow-hidden rounded-lg bg-gray-800 flex items-center justify-center">
                        <img src={libro.img} alt={libro.titulo} class="w-full h-full object-cover"/>
                        <div class="hidden w-full h-full items-center justify-center bg-gray-700 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0118 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
                            </svg>
                        </div>
                    </div>

                    <div class="flex flex-col gap-1 flex-1">
                        <p class="text-white text-2xl font-normal leading-tight text-title">
                            {libro.titulo}<br/>
                            <span class="text-white/80 text-xl text-page">{libro.autor}</span>
                        </p>
                    </div>
                    
                </div>
            ))}
        </div>
    </section>
    <Footer />
</Layout>

<style>
    @media (max-width: 720px) {
        section {
            background-color: #DBC5D9 !important;
        }
        .text-page { font-size: 1rem !important; }
        .text-title { font-size: 1.25rem !important; }
    }
</style>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<script is:inline>
    gsap.registerPlugin(ScrollTrigger);

    // Tarjetas entran desde abajo en stagger
    gsap.from('.libro-card', {
        y: 60,
        opacity: 0,
        duration: 0.5,
        stagger: 0.07,
        ease: 'back.out(1.4)',
        scrollTrigger: {
            trigger: 'section',
            start: 'top 85%',
        }
    });

    // Hover tarjeta — sube
    document.querySelectorAll('.libro-card').forEach(card => {
        card.addEventListener('mouseenter', () => {
            gsap.to(card, { y: -6, duration: 0.2, ease: 'power2.out' });
        });
        card.addEventListener('mouseleave', () => {
            gsap.to(card, { y: 0, duration: 0.2, ease: 'power2.out' });
        });
    });

    // Hover estrella — rebote con rotación
    document.querySelectorAll('.fav-btn').forEach(btn => {
        btn.addEventListener('mouseenter', () => {
            gsap.to(btn, { scale: 1.25, rotation: 15, duration: 0.2, ease: 'back.out(2)' });
        });
        btn.addEventListener('mouseleave', () => {
            gsap.to(btn, { scale: 1, rotation: 0, duration: 0.2, ease: 'power1.out' });
        });
    });

    // Hover botón comprar — escala
    document.querySelectorAll('.comprar-btn').forEach(btn => {
        btn.addEventListener('mouseenter', () => {
            gsap.to(btn, { scale: 1.04, duration: 0.15, ease: 'power1.out' });
        });
        btn.addEventListener('mouseleave', () => {
            gsap.to(btn, { scale: 1, duration: 0.15, ease: 'power1.out' });
        });
    });
</script>